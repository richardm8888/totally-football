---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE, FAQS } from '../consts';
import { Image } from 'astro:assets';
import IconImage from '../assets/icon.png';
import Main from '../layouts/Main.astro';
---
<style>
	/* ── SIGNUP ── */
	.signup {
		padding: 50px 24px 120px; text-align: center;
		position: relative; overflow: hidden;
	}
	.signup-inner { position: relative; z-index: 1; max-width: 560px; margin: 0 auto; }
	.signup-icon {
		width: 96px; height: auto; margin: 0 auto 30px; display: block;
	}
	.signup h2 {
		font-family: 'Bebas Neue', sans-serif; font-size: clamp(2.4rem, 7vw, 3.6rem);
		letter-spacing: 0.05em; line-height: 1; margin-bottom: 14px;
	}
	.signup h2 em { font-style: normal; color: var(--lime); }
	.signup p { color: var(--text-muted); font-size: 1rem; margin-bottom: 18px; line-height: 1.65; max-width: 420px; margin-left: auto; margin-right: auto; }
	.signup ul {
		max-width: 420px;
		margin-left: auto; 
		margin-right: auto;
		text-align: center;
	}
	.signup ul li {
		list-style-type: none;
		font-family: 'Barlow', sans-serif;
		font-size: 1.2rem;
		margin-bottom: 18px;
		color: var(--off-white);
	}
	.signup img.perks-icon {
		width: 20px; 
		filter: drop-shadow(0 2px 8px rgba(184,224,74,0.25));
		margin-right: 12px;
	}
</style>
<Main title={SITE_TITLE} description={SITE_DESCRIPTION} includeDiscoverMore={false} includeJoinTheSquad={false}>
	<section class="signup" id="signup">
		<div class="signup-inner">
			<Image class="signup-icon reveal" src={IconImage} alt="Totally Football" />
			<h2 class="reveal">Thanks for joining the <em>Squad</em></h2>
			<p class="section-eyebrow reveal">Now become part of the <span class="lime">Starting XI</span> for just <span class="lime">£1</span></p>
			<ul>
				<li>Early access to our Kickstarter</li>
				<li>Special Starting XI-only rewards and discounts</li>
				<li>Exclusive updates and behind-the-scenes content</li>
			</ul>

			<a class="btn-primary reveal" href="https://totally-football-board-game.myshopify.com/products/vip-access">Join the starting XI</a>
		</div>
	</section>
</Main>
