---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import LogoImage from '../../assets/logo.png';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
import Main from '../../layouts/Main.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<Main title={SITE_TITLE} description={SITE_DESCRIPTION} includeDiscoverMore={false}>

<style>

	.date {
		margin-bottom: 20px;
	}

	section.hero {
		position: relative;
		display: flex; flex-direction: column; align-items: center; justify-content: center;
		text-align: center; padding: 20px; overflow: hidden;
	}

	.hero-title {
		font-family: 'Bebas Neue', sans-serif;
		font-size: clamp(2.4rem, 6vw, 3.8rem); letter-spacing: 0.05em;
		text-align: center; margin-bottom: 20px; line-height: 1;
	}

	section.content {
		width: 100%;
		margin: 0 auto;
		padding: 20px;
	}

	section.content ul {
		list-style-type: none;
		display: flex;
		flex-direction: row;
		flex-wrap: wrap;
		gap: 40px;
	}
	section.content ul li {
		width: 100%;
		background-color: var(--navy-mid);
		padding: 20px;
	}

	@media (min-width: 800px) {
		section.content ul li {
			max-width: 300px;
		}
	}

	section.content ul li img {
		width: 100%;
		height: auto;
	}

	section.content ul li a {
		color: var(--lime);
		text-decoration: none;
		display: flex;
		flex-direction: column;
		gap: 10px;
	}
	section.content ul li a:hover {
		text-decoration: underline;
	}

	section.content ul li h4 {
		margin-bottom: 5px;
	}

</style>

<section class="hero">
	<h1 class="hero-title">Football Strategy & Tabletop Guides</h1>
</section>

<section class="content">
	<ul>
		{
			posts.map((post) => (
				<li>
					<a href={`/blog/${post.id}/`}>
						{post.data.heroImage && (
							<Image width={720} height={360} src={post.data.heroImage} alt={post.data.title} />
						)}
						<h4 class="title">{post.data.title}</h4>
					</a>
					<p class="date">
						<FormattedDate date={post.data.pubDate} />
					</p>
				</li>
			))
		}
	</ul>
</section>
