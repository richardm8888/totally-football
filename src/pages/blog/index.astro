---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import LogoImage from '../../assets/logo.png';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---


<!DOCTYPE html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />

		<style>

			.date {
				margin-bottom: 20px;
			}

			.hero-logo {
				position: relative; z-index: 2;
				margin-bottom: 36px;
				animation: fadeUp 0.7s 0.1s ease both;
				filter: drop-shadow(0 12px 48px rgba(184,224,74,0.18));
				width: 100%;
				max-width: 560px;
				height: auto;
			}

			/* Pitch lines */
			article::before {
				content: '';
				position: fixed; inset: 0;
				background:
					repeating-linear-gradient(-52deg, transparent, transparent 80px,
						rgba(184,224,74,0.03) 80px, rgba(184,224,74,0.03) 82px);
				pointer-events: none;
			}
			
			section.hero {
				position: relative;
				display: flex; flex-direction: column; align-items: center; justify-content: center;
				text-align: center; padding: 20px; overflow: hidden;
			}

			.hero-title {
				font-family: 'Bebas Neue', sans-serif;
				font-size: clamp(2.4rem, 6vw, 3.8rem); letter-spacing: 0.05em;
				text-align: center; margin-bottom: 20px; line-height: 1;
			}


			section.content {
				width: 100%;
				max-width: 800px;
				margin: 0 auto;
			}

			section.content ul {
				list-style-type: none;
			}
			section.content ul li {
				width: 100%;
				max-width: 300px;
			}

			section.content ul li img {
				width: 100%;
				height: auto;
			}

			section.content ul li a {
				color: var(--lime);
				text-decoration: none;
			}
			section.content ul li a:hover {
				text-decoration: underline;
			}

			section.content ul li h4 {
				margin-bottom: 5px;
			}

		</style>
	</head>
	<body>		
		<main>
			<section class="hero">
				<a href="/">
					<Image 
						class="hero-logo" 
						src={LogoImage} 
						alt="Totally Football"
						width={560}
					/>
				</a>
				<p class="section-eyebrow reveal">Blog</p>
				<h1 class="hero-title">Football Board Game Strategy & Guides</h1>
			</section>
			<section class="content">
				<ul>
					{
						posts.map((post) => (
							<li>
								<a href={`/blog/${post.id}/`}>
									{post.data.heroImage && (
										<Image width={720} height={360} src={post.data.heroImage} alt={post.data.title} />
									)}
									<h4 class="title">{post.data.title}</h4>
									<p class="date">
										<FormattedDate date={post.data.pubDate} />
									</p>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>

		<Footer />

		<script>
			const observer = new IntersectionObserver((entries) => {
				entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
			}, { threshold: 0.1 });
			document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
		</script>
		
	</body>
</html>
