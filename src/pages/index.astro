---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE, FAQS } from '../consts';
import { Image } from 'astro:assets';
import LogoImage from '../assets/logo.png';
import IconImage from '../assets/icon.png';
import WildcardImage from '../assets/wildcards.png';
import PlayersImage from '../assets/players.png';
import ChaosImage from '../assets/chaos.png';
import ActionImage from '../assets/actions2.png';
import Main from '../layouts/Main.astro';
import Hero from '../components/Home/Hero.astro';
import Mechanisms from '../components/Home/Mechanisms.astro';

const faqSchema = {
	"@context": "https://schema.org",
	"@type": "FAQPage",
	"mainEntity": FAQS.map((faq) => ({
		"@type": "Question",
		"name": faq.question,
		"acceptedAnswer": {
			"@type": "Answer",
			"text": faq.answer
		}
	}))
};
---

<Main title={SITE_TITLE} description={SITE_DESCRIPTION} includeDiscoverMore={true} includeJoinTheSquad={true}>
	<style>
		
		/* Phase pills */
		.hero-phases {
			position: relative; z-index: 2;
			display: flex; align-items: center; gap: 8px;
			margin-bottom: 20px;
			animation: fadeUp 0.7s 0.2s ease both;
		}
		.phase {
			font-family: 'Barlow Condensed', sans-serif; font-weight: 700;
			font-size: 0.95rem; letter-spacing: 0.08em; text-transform: uppercase;
			color: var(--white); padding: 5px 16px;
			background: rgba(255,255,255,0.07); border-radius: 4px;
		}
		.phase-arrow { color: var(--lime); font-size: 1rem; }
		

		/* WHAT IS IT */

		.what {
			background: var(--navy-dark);
			padding: 40px 20px; position: relative;
		}

		.what-inner {
			max-width: 900px;
			margin: 0 auto;
		}

		.what-sub {
			position: relative; 
			z-index: 2;
			font-size: clamp(1rem, 2.5vw, 1.15rem); 
			color: var(--off-white);
			line-height: 1.65; 
			margin-bottom: 20px;
			animation: fadeUp 0.7s 0.3s ease both;
			text-align: center;
		}

		.players-image, .chaos-image, .action-image {
			width: 100%; 
			height: auto; 
			margin: 0 auto;
		}

		/* FAQ */

		.faq {
			background: var(--navy-dark);
			padding: 20px; position: relative;
		}

		.faq-inner {
			max-width: 900px;
			margin: 0 auto;
		}

		.faq-question {
			color: var(--lime); text-align: center; margin-bottom: 10px;
		}

		.faq-answer {
			position: relative; 
			z-index: 2;
			font-size: clamp(1rem, 2.5vw, 1.15rem); 
			color: var(--off-white);
			line-height: 1.65; 
			margin-bottom: 20px;
			animation: fadeUp 0.7s 0.3s ease both;
			text-align: center;
		}

		/* ── HOW IT WORKS ── */
		.how {
			background: var(--navy);
			padding: 20px; position: relative;
		} 

		.how-subtitle {
			max-width: 900px;
			margin: 0 auto 20px;
			text-align: center;
			color: var(--off-white);
		}

		/* Phase cards */
		.phases-track {
			display: flex; 
			flex-direction: column;
			width: 100%;
			max-width: 900px; 
			margin: 0 auto 0;
			gap: 0;
		}

		@media (min-width: 700px) {
			.how .phases-track { flex-direction: row; }
		}

		.phase-card {
			flex: 1; position: relative;
			background: var(--navy-dark);
			border: 1px solid rgba(184,224,74,0.1);
			padding: 36px 28px; text-align: center;
			transition: border-color 0.25s, transform 0.25s;
		}
		.phase-card:first-child { border-radius: 8px 0 0 8px; }
		.phase-card:last-child  { border-radius: 0 8px 8px 0; }
		.phase-card:not(:last-child) { border-right: none; }
		.phase-card:hover { border-color: rgba(184,224,74,0.4); transform: translateY(-4px); z-index: 1; }
		.phase-num {
			width: 44px; height: 44px; border-radius: 50%;
			background: var(--lime); color: var(--navy-dark);
			font-family: 'Bebas Neue', sans-serif; font-size: 1.3rem;
			display: flex; align-items: center; justify-content: center;
			margin: 0 auto 18px;
		}
		.phase-label {
			font-family: 'Bebas Neue', sans-serif; font-size: 1.5rem;
			letter-spacing: 0.06em; color: var(--lime); margin-bottom: 10px;
		}
		.phase-desc { font-size: 0.88rem; color: var(--off-white); line-height: 1.6; }

		/* Arrow connectors */
		.phase-connector {
			display: flex; align-items: center; justify-content: center;
			padding: 0 4px; color: var(--lime); font-size: 1.4rem;
			position: relative; top: 0; flex-shrink: 0; margin-top: -4px;
			background: var(--navy);
		}

		/* Wildcards callout */
		.wildcard-strip {
			max-width: 900px; margin: 28px auto 0;
			background: rgba(184,224,74,0.06);
			border: 1px solid rgba(184,224,74,0.2);
			border-radius: 8px; padding: 22px 32px;
			display: flex; 
			flex-direction: column;
			align-items: center; 
			gap: 18px;
		}
		@media (min-width: 700px) {
			.wildcard-strip { flex-direction: row; text-align: left; }
		}
		.wildcard-strip .wc-icon img { filter: drop-shadow(0 4px 16px rgba(184,224,74,0.25)); }
		.wildcard-strip p { font-size: 0.92rem; color: var(--off-white); line-height: 1.55; }
		.wildcard-strip strong { color: var(--white); }

		/* ── FEATURES ── */
		.features { position: relative; padding: 100px 24px; background: var(--navy-dark); }
		.features-grid {
			display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
			gap: 24px; max-width: 960px; margin: 0 auto;
		}
		.feature-card {
			background: var(--navy);
			border: 1px solid rgba(255,255,255,0.06);
			border-radius: 8px; padding: 30px 26px;
			position: relative; overflow: hidden;
			transition: transform 0.2s, border-color 0.2s;
		}
		.feature-card::after {
			content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 3px;
			background: var(--lime); transform: scaleX(0); transform-origin: left;
			transition: transform 0.3s ease;
		}
		.feature-card:hover { transform: translateY(-4px); border-color: rgba(184,224,74,0.25); }
		.feature-card:hover::after { transform: scaleX(1); }
		.feature-icon { font-size: 2rem; margin-bottom: 14px; display: block; }
		.feature-title {
			font-family: 'Barlow Condensed', sans-serif; font-weight: 700;
			font-size: 1.15rem; letter-spacing: 0.04em; margin-bottom: 8px;
		}
		.feature-text { font-size: 0.88rem; color: var(--off-white); line-height: 1.65; }
	</style>

	<Hero />
	<Mechanisms />

	<!-- WHAT IS IT -->
	<section class="what">
		<div class="what-inner">
			<h2 class="section-title reveal">What is <span class="lime">Totally Football</span> Game?</h2>

			<p class="what-sub">
				Totally Football is a fast-paced football board game built on drama, where your tactics, players, and random events collide in matches where the momentum swings and football chaos ensues.
			</p>

			<p class="what-sub">
				Designed for football fans, tabletop gamers and competitive friends, the game blends accessible mechanics with meaningful tactical decisions that reward clever play and smart timing.
			</p>

			<p class="section-eyebrow reveal">Unpredictable Drama</p>

			<p class="what-sub">
				However good your strategy, football happens.
			</p>

			<p class="what-sub">
				VAR rules out your 90th minute winner
				Your star player wants out
				A dubious penalty changes everything

			</p>

			<p class="section-eyebrow reveal">Fast matches. Instant rivalries</p>

			<p class="what-sub">
				Totally Football is easy to learn, impossible to predict, and no two matches play out the same way.
			</p>
			<p class="what-sub">
				You'll be up and playing in minutes — and regretting a chaos card decision almost immediately.
			</p>
			<p class="what-sub">
				Absolutely no board game experience needed. (Make this big on the page, highlighted somehow)
			</p>
		</div>
	</section>

	<!-- HOW IT WORKS -->
	<section class="how">
		<p class="section-eyebrow reveal">How it works</p>
		<p class="what-sub">
			Deploy your players across three zones in the pitch to take on your opponent in a stat battle.
		</p>

		<p class="what-sub"></p>

		<div class="phases-track">
			<div class="phase-card reveal">
				<div class="phase-num">1</div>
				<div class="phase-label">Build-Up</div>
				<p class="phase-desc">Dribble and pass your way up the pitch into a good shooting position.<br />Use action cards to swing key duels in your favour.</p>
			</div>
			<div class="phase-card reveal reveal-delay-1">
				<div class="phase-num">2</div>
				<div class="phase-label">Progression</div>
				<p class="phase-desc">Continue moving up the pitch or take a shot at goal?<br />Watch-out for chaos cards that can change everything.</p>
			</div>
			<div class="phase-card reveal reveal-delay-2">
				<div class="phase-num">3</div>
				<div class="phase-label">Final Third</div>
				<p class="phase-desc">The pressure is on. Win the decisive duel in front of goal and put the ball in the net to take the bragging rights.</p>
			</div>
		</div>

		<div class="wildcard-strip reveal">
			<p>
				<strong>Chaos cards change everything.</strong>
				<br />
				Deploy special cards at any moment to swing a duel, disrupt your opponent's rhythm, or protect your lead. Just like the real thing — chaos is always one move away.
			</p>
		</div>
	</section>

	<!-- FEATURES -->
	<section class="features">
		<p class="section-eyebrow reveal">Why you'll love it</p>
		<h2 class="section-title reveal">Built for <span style="color:var(--lime)">Football</span> Fans</h2>
		<div class="features-grid">
			<div class="feature-card reveal">
				<h3 class="feature-title">1v1 Duels</h3>
				<p class="feature-text">Top-trumps style stat battles mean every card play is a tactical decision. Know your squad and you'll know when to strike.</p>
			</div>
			<div class="feature-card reveal reveal-delay-1">
				<h3 class="feature-title">Strategic</h3>
				<p class="feature-text">Squad selection, phase management, chaos card timing — there's always a smarter move if you can find it.</p>
			</div>
			<div class="feature-card reveal reveal-delay-2">
				<h3 class="feature-title">Fast to Play</h3>
				<p class="feature-text">Simple enough to pick up in minutes, deep enough to keep you coming back every match night.</p>
			</div>
			<div class="feature-card reveal reveal-delay-3">
				<h3 class="feature-title">2-4 Players</h3>
				<p class="feature-text">Perfect for head-to-head rivalries or a full league night with friends. Scales brilliantly at any squad size.</p>
			</div>
		</div>
	</section>

	<!-- FAQ -->
	<section class="faq">
		<div class="faq-inner">
			<p class="section-eyebrow reveal">FAQ</p>
			<h2 class="section-title reveal">Frequently asked questions</h2>

			{
				FAQS.map((faq) => {
					return (
						<h3 class="faq-question reveal">{faq.question}</h3>
						<p class="faq-answer reveal">{faq.answer}</p>
					)
				})
			}

			</div>
	</section>

	<script
		type="application/ld+json"
		set:html={JSON.stringify(faqSchema)}
	></script>
</Main>
