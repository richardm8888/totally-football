---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Main from './Main.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;
---


<Main title={title} description={description}>

<style>

	.date {
		margin-bottom: 20px;
	}
	
	section.hero {
		position: relative;
		display: flex; flex-direction: column; align-items: center; justify-content: center;
		text-align: center; padding: 20px; overflow: hidden;
	}

	section.hero img.article-image {
		width: 100%;
		max-width: 600px;
		height: auto;
		margin-bottom: 20px;
	}

	.hero-title {
		font-family: 'Bebas Neue', sans-serif;
		font-size: clamp(2.4rem, 6vw, 3.8rem); letter-spacing: 0.05em;
		text-align: center; margin-bottom: 20px; line-height: 1;
	}

	section.content {
		width: 100%;
		margin: 0 auto;
		padding: 0 20px;
	}

</style>
	
<article>
	<section class="hero">
		{heroImage && <Image class="article-image" src={heroImage} alt={title} fit="constrain" />}
		<h1 class="hero-title">{title}</h1>
	</section>
	<section class="content">
		<div class="date">
			<FormattedDate date={pubDate} />
			{
				updatedDate && (
					<div class="last-updated-on">
						Last updated on <FormattedDate date={updatedDate} />
					</div>
				)
			}
		</div>
		<slot />
	</section>
</article>
