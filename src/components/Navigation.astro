---
import { Image } from 'astro:assets';
import CloseImage from '../assets/close.png';
import MenuImage from '../assets/menu.png';
---

<div id="burger-menu">
    <div class="burger-menu-inner">
        <div class="burger-menu-inner-header">
            <a href="#" class="nav-link" onClick="document.getElementById('burger-menu').classList.remove('open');">
                <Image
                    src={CloseImage} 
                    alt="Close Menu"
                    height={"50"}
                />
            </a>
        </div>
        <a href="/" class="nav-link">Home</a>
        <!--<a href="/how-to-play" class="nav-link">How to play</a>
        <a href="/the-cards" class="nav-link">The cards</a>-->
        <a href="/about-us" class="nav-link">About us</a>
        <a href="/blog" class="nav-link">Blog</a>
        <a href="#signup" class="btn-primary" onClick="document.getElementById('burger-menu').classList.remove('open');">Join the squad</a>
    </div>
</div>

<nav>
    <a href="/" class="nav-link">Home</a>
    <!--<a href="/how-to-play" class="nav-link">How to play</a>
    <a href="/the-cards" class="nav-link">The cards</a>-->
    <a href="/about-us" class="nav-link">About us</a>
    <a href="/blog" class="nav-link">Blog</a>
    <a href="#signup" class="btn-primary">Join the squad</a>

    <a class="burger-menu-btn" onClick="document.getElementById('burger-menu').classList.toggle('open');">
        <Image 
            src={MenuImage} 
            alt="Open Menu"
            height={"50"}
        />
    </a>
</nav>

<style>
    nav {
        height: 100px;
        padding: 20px 0;
        display: flex;
        flex-direction: row;
        justify-content: space-between;
        align-items: center;
        flex-grow: 1;
        max-width: 70%;
    }

    a.nav-link {
        font-family: 'Bebas Neue', sans-serif;
        color: var(--white);
        font-size: 21px;
        text-decoration: none;
    }
    a.nav-link:hover {
        color: var(--lime);
    }

    .burger-menu-btn {
        display: none;
    }

    div#burger-menu {
        position: fixed;
        width: 0;
        height: 100vh;
        top: 0;
        right: 0;
        overflow: hidden;
        display: flex;
        flex-direction: row;
        justify-content: flex-end;
        transition: width 1s;
    } 

    div#burger-menu.open {
        width: 100vw;
    }

    div#burger-menu .burger-menu-inner {
        width: 100%;
        height: 100%;
        background-color: var(--navy-mid);
        display: flex;
        flex-direction: column;
        padding: 0 20px 20px 20px;
        gap: 20px;
        z-index: 500;
        overflow: hidden;
    }

    div#burger-menu .burger-menu-inner .burger-menu-inner-header {
        display: flex;
        width: 100%;
        height: 100px;
        flex-direction: row;
        justify-content: flex-end;
        align-items: center;
    }

    div#burger-menu.open .burger-menu-bg-blur {
        width: 100%;
        height: 100vh;
        position: absolute;
        top: 0;
        left: 0;
        background-color: var(--navy-mid-transparent);
        z-index: 500;
    }

    @media (max-width: 799px) {
        nav {
            justify-content: flex-end;
        }

        nav > a.nav-link, nav > a.btn-primary {
            display: none;
        }

        nav .burger-menu-btn {
            display: inline;
        }
    }
</style>
