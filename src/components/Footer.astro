---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import LogoImage from '../assets/logo.png';
import IconImage from '../assets/icon.png';

import Facebook from '../assets/socials/facebook.png';
import Twitter from '../assets/socials/x-twitter.png';
import Instagram from '../assets/socials/instagram.png';
import TikTok from '../assets/socials/tiktok.png';

const today = new Date();

const latestPost = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
)?.[0];

const { includeDiscoverMore } = Astro.props;
---

<!-- SIGNUP -->
<section class="signup" id="signup">
	<div class="signup-inner">
		<Image class="signup-icon reveal" src={IconImage} alt="Totally Football" />
		<h2 class="reveal">Join the <em>Squad</em></h2>
		<div class="ml-embedded reveal" data-form="uS3lEH"></div>
	</div>
</section>

{includeDiscoverMore ? (
	<!-- DISCOVER MORE -->
	<section class="more">
		<div class="more-inner">
			<p class="section-eyebrow reveal">Discover more</p>
			<h2 class="section-title reveal">
				Football Strategy & Tabletop Guides
			</h2>

			<p class="more-sub reveal">
				Explore tactical football game guides, tabletop strategy articles and behind-the-scenes design insights from Totally Football Game.
			</p>
			
			{latestPost && (
				<div class="featured-article reveal">

					<a href={`/blog/${latestPost.id}/`} class="featured-link">

						{latestPost.data.heroImage && (
							<Image src={latestPost.data.heroImage} alt={latestPost.data.title} fit="constrain" />
						)}
						<div class="featured-item">
							<p class="tag">Featured Article</p>
							<h3>{latestPost.data.title}</h3>
							<p>{latestPost.data.description}</p>
						</div>
					</a>

				</div>
			)}		

			<div class="more-actions reveal">
				<a href="/blog/" class="btn-primary">
					View All Articles
				</a>
			</div>
		</div>
	</section>
) : null}

<!-- FOOTER -->
<footer>
	<div class="footer-inner">
		<Image class="footer-logo" src={LogoImage} alt="Totally Football" />
		<div class="socials">
			<a href="https://www.instagram.com/totallyfootballgame" target="_blank"><Image src={Instagram} alt="Instagram" width="40" /></a>
			<a href="https://www.facebook.com/totallyfootballgame" target="_blank"><Image src={Facebook} alt="Facebook" width="40" /></a>
			<a href="https://x.com/TFBoardGame" target="_blank"><Image src={Twitter} alt="X (Formerly Twitter)" width="40" /></a>
			<a href="https://www.tiktok.com/@totallyfootballgame" target="_blank"><Image src={TikTok} alt="TikTok" width="40" /></a>
		</div>
	</div>
	<p>&copy; {today.getFullYear()} Totally Football. All rights reserved.</p>
</footer>

<style>
	.more {
		background: var(--navy);
		padding: 100px 24px; position: relative;
	}
	.more::before {
		content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px;
		background: linear-gradient(90deg, transparent 0%, var(--lime) 50%, transparent 100%);
	}

	.more-inner {
		max-width: 900px;
		margin: 0 auto;
	}

	.more-sub {
		position: relative; 
		z-index: 2;
		font-size: clamp(1rem, 2.5vw, 1.15rem); 
		color: var(--text-muted);
		line-height: 1.65; 
		margin-bottom: 20px;
		animation: fadeUp 0.7s 0.3s ease both;
		text-align: center;
	}
	
	footer {
		background-color: var(--navy-dark);
		padding: 36px 24px; 
		text-align: center;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 20px;
	}
	footer .footer-inner {
		width: 100%;
		display: flex;
		flex-direction: row;
		justify-content: space-between;
	}

	footer .footer-inner .socials {
		width: 100%;
		display: flex;
		flex-direction: row;
		justify-content: flex-end;
		gap: 20px;
	}

	.footer-logo { width: auto; height: 50px; margin: 0 auto 12px; display: block; filter: drop-shadow(0 2px 12px rgba(184,224,74,0.15)); }
	footer p { font-size: 0.78rem; color: var(--off-white); }

	.featured-link {
		display: flex;
		flex-direction: column;
		justify-content: space-between;
		gap: 30px;
		width: 100%;
		text-decoration: none;
		color: var(--white);
	}

	@media (min-width: 700px) {
		.featured-link {
			flex-direction: row;
		}
	}

	.featured-link:hover {
		text-decoration: underline;
	}

	.tag {
		color: var(--lime);
	}

	.featured-item {
		display: flex;
		flex-direction: column;
		gap: 10px;
	}

	.featured-article img {
		height: 200px;
		width: auto;
	}

	.more-actions {
		text-align: center;
		margin-top: 40px;
	}

	/* ── SIGNUP ── */
	.signup {
		padding: 20px; text-align: center;
		background: linear-gradient(170deg, var(--navy-dark) 0%, #0a1420 100%);
		position: relative; overflow: hidden;
	}
	.signup::before {
		content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px;
		background: linear-gradient(90deg, transparent 0%, var(--lime) 50%, transparent 100%);
	}
	.signup-inner { position: relative; z-index: 1; max-width: 560px; margin: 0 auto; }
	.signup-icon {
		width: 96px; 
		height: auto; 
		margin: 0 auto 30px; 
		display: block;
	}
	.signup h2 {
		font-family: 'Bebas Neue', sans-serif; font-size: clamp(2.4rem, 7vw, 3.6rem);
		letter-spacing: 0.05em; line-height: 1; margin-bottom: 14px;
	}
	.signup h2 em { font-style: normal; color: var(--lime); }
	.signup p { color: var(--text-muted); font-size: 1rem; margin-bottom: 38px; line-height: 1.65; max-width: 420px; margin-left: auto; margin-right: auto; }
	.ml-embedded { max-width: 480px; margin: 0 auto; }
</style>
