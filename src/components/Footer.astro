---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import LogoImage from '../assets/logo.png';
const today = new Date();

const latestPost = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
)?.[0];
---


<!-- DISCOVER MORE -->
<section class="more">
	<div class="more-inner">
		<p class="section-eyebrow reveal">Discover more</p>
		<h2 class="section-title reveal">
			Football Strategy & Tabletop Guides
		</h2>

		<p class="more-sub reveal">
			Explore tactical football game guides, tabletop strategy articles and behind-the-scenes design insights from Totally Football Game.
		</p>
		
		{latestPost && (
			<div class="featured-article reveal">

				<a href={`/blog/${latestPost.id}/`} class="featured-link">

					{latestPost.data.heroImage && (
						<Image src={latestPost.data.heroImage} alt={latestPost.data.title} fit="constrain" />
					)}
					<div class="featured-item">
						<p class="tag">Featured Article</p>
						<h3>{latestPost.data.title}</h3>
						<p>{latestPost.data.description}</p>
					</div>
				</a>

			</div>
		)}		

		<div class="more-actions reveal">
			<a href="/blog/" class="btn-primary">
				View All Articles
			</a>
		</div>
	</div>
</section>

<!-- FOOTER -->
<footer>
	<Image class="footer-logo" src={LogoImage} alt="Totally Football" />
	<p>&copy; {today.getFullYear()} Totally Football. All rights reserved.</p>
</footer>

<style>
	.more {
		background: var(--navy);
		padding: 100px 24px; position: relative;
	}
	.more::before {
		content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px;
		background: linear-gradient(90deg, transparent 0%, var(--lime) 50%, transparent 100%);
	}

	.more-inner {
		max-width: 900px;
		margin: 0 auto;
	}

	.more-sub {
		position: relative; 
		z-index: 2;
		font-size: clamp(1rem, 2.5vw, 1.15rem); 
		color: var(--text-muted);
		line-height: 1.65; 
		margin-bottom: 20px;
		animation: fadeUp 0.7s 0.3s ease both;
		text-align: center;
	}
	
	footer {
		background: #0a0f18;
		border-top: 1px solid rgba(255,255,255,0.05);
		padding: 36px 24px; text-align: center;
	}
	.footer-logo { width: 180px; height: auto; margin: 0 auto 12px; display: block; filter: drop-shadow(0 2px 12px rgba(184,224,74,0.15)); }
	footer p { font-size: 0.78rem; color: var(--text-muted); }

	.featured-link {
		display: flex;
		flex-direction: column;
		justify-content: space-between;
		gap: 30px;
		width: 100%;
		text-decoration: none;
		color: var(--white);
	}

	@media (min-width: 700px) {
		.featured-link {
			flex-direction: row;
		}
	}

	.featured-link:hover {
		text-decoration: underline;
	}

	.tag {
		color: var(--lime);
	}

	.featured-item {
		display: flex;
		flex-direction: column;
		gap: 10px;
	}

	.featured-article img {
		height: 200px;
		width: auto;
	}

	.more-actions {
		text-align: center;
		margin-top: 40px;
	}
</style>
